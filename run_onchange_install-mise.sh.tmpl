#!/bin/bash
# config.toml hash: {{ include "dot_config/mise/config.toml" | sha256sum }}

set -eu

MISE_PATH="$HOME/.local/bin/mise"

if [ ! -f "$MISE_PATH" ]; then
    echo "Installing mise..."
    curl -fsSL https://mise.run | sh
fi

eval "$("$MISE_PATH" activate bash)"

echo "Installing mise tools..."
mise install --yes
