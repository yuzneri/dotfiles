{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "language": "japanese",
  "alwaysThinkingEnabled": true,
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "env": {
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "64000"
  },
  "permissions": {
    "allow": [
      "LS", "Read", "Edit", "Write", "Glob", "Grep",
      "WebFetch", "WebSearch",
      "Task", "ToolSearch",

      "Bash(cd:*)", "Bash(pwd:*)", "Bash(mkdir:*)",
      "Bash(ls:*)", "Bash(find:*)", "Bash(tree:*)",
      "Bash(stat:*)", "Bash(file:*)",
      "Bash(realpath:*)", "Bash(readlink:*)",

      "Bash(cat:*)", "Bash(head:*)", "Bash(tail:*)",
      "Bash(grep:*)", "Bash(wc:*)",
      "Bash(sort:*)", "Bash(uniq:*)", "Bash(diff:*)",
      "Bash(tr:*)", "Bash(cut:*)", "Bash(awk:*)",
      "Bash(jq:*)",

      "Bash(echo:*)", "Bash(which:*)",
      "Bash(env:*)", "Bash(printenv:*)",
      "Bash(date:*)", "Bash(whoami:*)", "Bash(uname:*)",

      "Bash(node:*)", "Bash(npx:*)", "Bash(bunx:*)",
      "Bash(python:*)", "Bash(python3:*)",
      "Bash(make:*)",

      "Bash(curl:*)", "Bash(wget:*)",
      "Bash(tar:*)", "Bash(unzip:*)", "Bash(gunzip:*)",

      "Bash(git:*)", "Bash(gh:*)",
      "Bash(docker:*)",

      "mcp__firecrawl-mcp__*",
      "mcp__deepwiki__*",
      "mcp__context7__*",
      "mcp__brightdata__*",
      "mcp__serena__*"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets/**)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -n \"$TMUX_PANE\" ]; then printf '\\a' > $(tmux display-message -p -t \"$TMUX_PANE\" '#{pane_tty}'); else printf '\\a'; fi"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt|elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -n \"$TMUX_PANE\" ]; then printf '\\a' > $(tmux display-message -p -t \"$TMUX_PANE\" '#{pane_tty}'); else printf '\\a'; fi"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bunx -y ccstatusline@latest",
    "padding": 0
  }
}
